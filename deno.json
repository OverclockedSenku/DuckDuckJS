{
  "name": "@overclockedsenku/duckduckjs",
  "version": "26.1.0",
  "exports": "./mod.ts",
  "license": "Apache-2.0",
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "src/**/*.ts",
      "mod.ts"
    ]
  },
  "tasks": {
    "test": "deno run -A src/cli.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "compile:linux": "deno compile --allow-net --target x86_64-unknown-linux-gnu --output bin/duckduckjs-linux src/cli.ts",
    "compile:win": "deno compile --allow-net --target x86_64-pc-windows-msvc --output bin/duckduckjs-win.exe src/cli.ts",
    "compile:mac-intel": "deno compile --allow-net --target x86_64-apple-darwin --output bin/duckduckjs-macos-intel src/cli.ts",
    "compile:mac-arm": "deno compile --allow-net --target aarch64-apple-darwin --output bin/duckduckjs-macos-arm src/cli.ts",
    "compile:all": "deno task compile:linux && deno task compile:win && deno task compile:mac-intel && deno task compile:mac-arm",
    "test:integration": "deno run --allow-net tests/engine_test.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "cheerio": "npm:cheerio@^1.2.0"
  }
}
